# Blog source.
# Leave CMS_PROVIDER unset (or "sample") to use the bundled sample posts in lib/sample-posts.ts.
# Set to "sanity" to pull posts from a Sanity dataset.
CMS_PROVIDER=

# --- Sanity (only needed when CMS_PROVIDER=sanity) ---
# Found in your Sanity project settings / sanity.config.ts
SANITY_PROJECT_ID=
SANITY_DATASET=production
