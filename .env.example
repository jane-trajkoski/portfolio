# Copy this file to ".env" and fill in real values. .env is gitignored; this file is NOT — keep placeholders only.

# Neon Postgres. Pooled URL for the app:
DATABASE_URL=
# Direct (unpooled) URL for prisma migrate / db push:
DIRECT_URL=

# Password for the /admin editor:
ADMIN_PASSWORD=change-me

# Vercel Blob (image uploads)
BLOB_READ_WRITE_TOKEN=

# Resend (contact form email)
RESEND_API_KEY=
CONTACT_TO=
CONTACT_FROM=
